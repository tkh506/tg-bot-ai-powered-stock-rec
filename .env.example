# ── OpenRouter ─────────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# ── Telegram ───────────────────────────────────────────────────────────────────
# Create a bot via @BotFather, then get the chat ID
# For a group chat the ID will be negative (e.g. -100123456789)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=-100123456789

# Your personal Telegram user ID — only this user can send /report to trigger an ad-hoc run
# Find your ID by messaging @userinfobot on Telegram
TELEGRAM_OWNER_USER_ID=YOUR_TELEGRAM_USER_ID_HERE

# ── News APIs ──────────────────────────────────────────────────────────────────
# NewsAPI: https://newsapi.org/account
NEWSAPI_KEY=YOUR_NEWSAPI_KEY_HERE

# Alpha Vantage (paid): https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_KEY=YOUR_ALPHAVANTAGE_KEY_HERE

# ── GCP (optional, only if using Secret Manager) ───────────────────────────────
# GCP_PROJECT_ID=your-gcp-project-id

# ── New Data Sources ────────────────────────────────────────────────────────────
# Finnhub: https://finnhub.io/dashboard (free tier — stock news + fundamentals)
FINNHUB_API_KEY=

# Marketaux: https://www.marketaux.com/profile/dashboard (free tier — financial news)
MARKETAUX_API_KEY=

# NewsData.io: https://newsdata.io/api-key (free tier — 200 credits/day)
NEWSDATA_API_KEY=

# FRED (Federal Reserve): https://fred.stlouisfed.org/docs/api/api_key.html (free)
FRED_API_KEY=

# Adanos Software: https://adanos.org (free tier — 250 req/month)
# Reddit Stock, X.com Stock, Polymarket, Reddit Crypto sentiment APIs
ADANOS_API_KEY=

# ApeWisdom: no API key required (public API)
